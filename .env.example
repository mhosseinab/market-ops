# Copy to .env (gitignored) for local dev. NO real secrets belong in this file
# or in .env; seller tokens, DB credentials, and model keys are env/secret-store
# only (dk-p0-monorepo.md §8, PRD §12.3/§15.2).

# ─── Dev database ───────────────────────────────────────────────────
# PostgreSQL 18. The dev database is provisioned by deploy/compose.dev.yml in S2;
# the postgres MCP server (.mcp.json) reads this via ${DATABASE_URL}, read-only.
DATABASE_URL=postgres://market_ops:market_ops@localhost:5432/market_ops?sslmode=disable

# ─── LLM plane ──────────────────────────────────────────────────────
# The LLM plane holds a read/Draft-only gateway token and NO database URL.
LLM_GATEWAY_TOKEN=

# OpenAI-compatible model endpoint (base_url + key). Model-agnostic transport.
LLM_BASE_URL=
LLM_API_KEY=

# ─── Dev observability toggles (unset ⇒ wiring disabled) ────────────
# Spotlight sidecar (dev-only Sentry UI on :8969); unset disables all Sentry
# wiring. The dev-stack default value is set once in the S2 block below.
# LangSmith LLM-call tracing — opt-in, NEVER set in CI (sends prompts to the cloud).
LANGSMITH_TRACING=
LANGSMITH_API_KEY=

# --- S3 core service ---
# OpenTelemetry SDK switch for the Go core. Unset/false ⇒ no exporter, no-op
# tracer provider (fails closed). The OTLP endpoint itself is configured via the
# standard OTEL_EXPORTER_OTLP_* vars documented alongside the dev stack.
OTEL_ENABLED=

# --- S2 dev stack ---------------------------------------------------------
# Endpoints served by deploy/compose.dev.yml (`task dev`). DATABASE_URL above
# (defined by S1) already points at this dev Postgres 18 container — not
# redeclared here to avoid a duplicate key.
#
# OpenTelemetry OTLP ingest — the otel-collector listens on 4317 (gRPC) and
# 4318 (HTTP); every plane's SDK exports here. Default to the HTTP endpoint.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Spotlight dev-observability sidecar stream (dev-only; the single SENTRY_SPOTLIGHT
# definition — set here so the dev stack is wired out of the box).
SENTRY_SPOTLIGHT=http://localhost:8969/stream
