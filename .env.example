# Optional local configuration overrides. `task up` works without this file;
# copy it to .env only when overriding a default. Never commit .env.
#
# The LLM service does not read this file automatically (its settings are
# environment-only). Give it only the LLM_* variables it needs; never give the
# LLM process DATABASE_URL or CONNECTOR_ENCRYPTION_KEY.

# Core service ---------------------------------------------------------------
APP_ENV=dev
HTTP_ADDR=:8080
DATABASE_URL=postgres://market_ops:market_ops@localhost:5432/market_ops?sslmode=disable
DK_API_BASE_URL=http://localhost:8090
CONNECTOR_ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTES
LLM_SERVICE_URL=http://localhost:8100
LLM_GATEWAY_TOKEN=CHANGE_ME_RANDOM_256_BIT_TOKEN
LOG_LEVEL=info

# Chat can be disabled globally or for comma-separated marketplace-account UUIDs.
CHAT_KILL_SWITCH=false
CHAT_KILL_SWITCH_ACCOUNTS=

# Daily digest. An empty NOTIFY_FROM_ADDR disables email; Mailpit listens on
# localhost:1025 in local development.
SMTP_ADDR=localhost:1025
NOTIFY_FROM_ADDR=
APP_BASE_URL=http://localhost:8888
NOTIFY_LOCALE=fa-IR
NOTIFY_REGION=IR
CURRENCY_CONTRACT_VERSION=v1

# Core observability. Both are opt-in. Spotlight is development-only.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_SPOTLIGHT=

# LLM service ---------------------------------------------------------------
# Safe offline default. Production may use openai_compatible only after the
# gated provider benchmark and explicit human approval.
LLM_PROVIDER_KIND=mock
LLM_PROVIDER_BASE_URL=http://localhost:11434/v1
LLM_PROVIDER_API_KEY=
LLM_PROVIDER_MODEL=mock-model
LLM_PROVIDER_TIMEOUT_SECONDS=30
LLM_MAX_OUTPUT_TOKENS=1024
LLM_GRAPH_RECURSION_LIMIT=24
LLM_TOOL_CALL_RUN_LIMIT=12
LLM_PER_TOOL_CALL_RUN_LIMIT=4
LLM_PER_TOOL_TIMEOUT_SECONDS=15
LLM_NODE_TRANSIENT_RETRIES=1
LLM_CHAT_DISABLED_GLOBAL=false
# JSON array when used, for example: ["00000000-0000-0000-0000-000000000003"]
LLM_CHAT_DISABLED_ACCOUNTS=[]

# LLM observability. These variables use the LLM_ prefix because the service's
# Pydantic settings use env_prefix="LLM_". LangSmith sends model data outside
# the deployment and must remain off unless that transfer is explicitly approved.
LLM_SENTRY_SPOTLIGHT=
LLM_LANGSMITH_TRACING=false
LLM_LANGSMITH_API_KEY=

# Web and extension build-time values ---------------------------------------
# The production SPA should normally use same-origin /api behind Caddy.
VITE_GATEWAY_BASE_URL=/api
VITE_MARKETPLACE_ACCOUNT_ID=00000000-0000-0000-0000-000000000003
VITE_SENTRY_SPOTLIGHT=

# The extension needs absolute HTTPS production URLs at build time. These
# localhost values are only examples; its manifest must also grant the selected
# gateway origin in host_permissions (see DEPLOYMENT.md).
VITE_WEB_BASE_URL=http://localhost:8888
