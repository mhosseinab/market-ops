{
  "uid": "dk-activation",
  "title": "DK · Activation & first value",
  "description": "First-value funnel: connection → sync → first product view (§17.2 < 2s).",
  "tags": [
    "dk-p0",
    "activation"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 2,
      "type": "timeseries",
      "title": "Connection & capability lifecycle",
      "description": "§18 connection/capability lifecycle events (analytics_events, family=connection).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (name) (rate(analytics_events{family=\"connection\"}[5m]))",
          "legendFormat": "{{name}}",
          "refId": "B",
          "range": true
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Sync & import lifecycle",
      "description": "§18 sync/import lifecycle events.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (name) (rate(analytics_events{family=\"sync\"}[5m]))",
          "legendFormat": "{{name}}",
          "refId": "D",
          "range": true
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "First-view P95 (§17.2 common views < 2s)",
      "description": "P95 of the common product views. §17.2 target: < 2s.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_bucket{http_route=~\"/today|/market|/events\"}[5m])))",
          "legendFormat": "p95",
          "refId": "F",
          "range": true
        }
      ]
    }
  ]
}
