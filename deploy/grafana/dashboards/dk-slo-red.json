{
  "uid": "dk-slo-red",
  "title": "DK · SLO / RED overview (§17.2)",
  "description": "§17.2 performance & reliability: RED per endpoint + P95 targets + collection-layer health.",
  "tags": [
    "dk-p0",
    "slo",
    "red"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 56,
      "type": "timeseries",
      "title": "Request rate by route",
      "description": "RED · Rate: gateway requests per route (S33 gateway seam).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (http_route) (rate(http_server_request_duration_count[5m]))",
          "legendFormat": "{{http_route}}",
          "refId": "D",
          "range": true
        }
      ]
    },
    {
      "id": 58,
      "type": "timeseries",
      "title": "Error rate by class",
      "description": "RED · Errors: 4xx/5xx rate.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (http_status_class) (rate(http_server_request_duration_count{http_status_class=~\"4xx|5xx\"}[5m]))",
          "legendFormat": "{{http_status_class}}",
          "refId": "F",
          "range": true
        }
      ]
    },
    {
      "id": 60,
      "type": "timeseries",
      "title": "P95 latency by route (§17.2)",
      "description": "RED · Duration: P95 per route against §17.2 targets (views < 2s, approval card < 5s, chat < 10s).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_bucket[5m])))",
          "legendFormat": "{{http_route}}",
          "refId": "H",
          "range": true
        }
      ]
    },
    {
      "id": 62,
      "type": "stat",
      "title": "Collector: OTLP metric points exported",
      "description": "Collection-layer health: metric points leaving the collector (docs/14). Zero ⇒ instrumentation or collector broken.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(otelcol_exporter_sent_metric_points[5m]))",
          "legendFormat": "exported",
          "refId": "J",
          "range": true
        }
      ]
    }
  ]
}
