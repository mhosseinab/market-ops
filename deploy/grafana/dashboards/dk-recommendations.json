{
  "uid": "dk-recommendations",
  "title": "DK · Recommendation coverage & blockers",
  "description": "Recommendation coverage and the gate blockers that suppress an action.",
  "tags": [
    "dk-p0",
    "recommendations"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 26,
      "type": "timeseries",
      "title": "Recommendation & simulation events (by name)",
      "description": "§18 recommendation/simulation family.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (name) (rate(analytics_events{family=\"recommendation\"}[1h]))",
          "legendFormat": "{{name}}",
          "refId": "Z",
          "range": true
        }
      ]
    },
    {
      "id": 28,
      "type": "timeseries",
      "title": "Execution gate blocks (blockers, by gate)",
      "description": "EXE-001 revalidation gate blocks by gate — the coverage blockers (S18).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (gate) (rate(execution_gate_blocks[1h]))",
          "legendFormat": "{{gate}}",
          "refId": "B",
          "range": true
        }
      ]
    }
  ]
}
