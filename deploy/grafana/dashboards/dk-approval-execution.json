{
  "uid": "dk-approval-execution",
  "title": "DK · Approval & execution integrity",
  "description": "The never-cut approval/execution boundaries: write attempts, dedup, audit integrity, reconciliation, card latency.",
  "tags": [
    "dk-p0",
    "approval",
    "execution"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 30,
      "type": "timeseries",
      "title": "External write attempts (by state)",
      "description": "EXE-002 external price-write attempts by result state (S18).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (external_state) (rate(execution_write_attempts[5m]))",
          "legendFormat": "{{external_state}}",
          "refId": "D",
          "range": true
        }
      ]
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Idempotency dedup hits",
      "description": "Duplicate requests that wrote nothing — idempotency working (never-cut).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(execution_dedup_hits[5m]))",
          "legendFormat": "dedup_hits",
          "refId": "F",
          "range": true
        }
      ]
    },
    {
      "id": 34,
      "type": "stat",
      "title": "Audit-write failures (never-cut, must be 0)",
      "description": "Any non-zero value = an audit append that forced a rollback. Fail-closed, page-worthy.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(execution_audit_write_failures[24h]))",
          "legendFormat": "audit_failures",
          "refId": "H",
          "range": true
        }
      ]
    },
    {
      "id": 36,
      "type": "stat",
      "title": "Pending reconciliation (30m)",
      "description": "EXE-003 unknown write results parked pending reconciliation.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(execution_pending_reconciliation[30m]))",
          "legendFormat": "pending",
          "refId": "J",
          "range": true
        }
      ]
    },
    {
      "id": 38,
      "type": "timeseries",
      "title": "Approval-card P95 (§17.2 < 5s, no model dep)",
      "description": "Approval card latency. §17.2 target: < 5s without model dependency.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_bucket{http_route=~\"/approvals/card\"}[5m])))",
          "legendFormat": "p95",
          "refId": "L",
          "range": true
        }
      ]
    }
  ]
}
