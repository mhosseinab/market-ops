{
  "uid": "dk-wvra",
  "title": "DK · WVRA by execution mode",
  "description": "Weekly Verified Recommended Action split by execution mode (write vs recommend-only).",
  "tags": [
    "dk-p0",
    "wvra"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 8,
      "type": "timeseries",
      "title": "Execution-family lifecycle (by name)",
      "description": "Execution/reconciliation/recommend-only/outcome events (§18).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (name) (rate(analytics_events{family=\"execution\"}[1h]))",
          "legendFormat": "{{name}}",
          "refId": "H",
          "range": true
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Recommend-only vs terminal writes",
      "description": "WVRA denominator/numerator: recommend-only matches vs reconciled terminal writes (S18 counters).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(execution_recommend_only[1h]))",
          "legendFormat": "recommend_only",
          "refId": "J",
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (external_state) (rate(execution_terminal_results[1h]))",
          "legendFormat": "terminal {{external_state}}",
          "refId": "K",
          "range": true
        }
      ]
    }
  ]
}
