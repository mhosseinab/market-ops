{
  "uid": "dk-unit-economics",
  "title": "DK · Unit economics",
  "description": "Unit economics from §17.3 granular cost counters.",
  "tags": [
    "dk-p0",
    "economics"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 48,
      "type": "timeseries",
      "title": "Variable cost by kind (§17.3)",
      "description": "Every §17.3 variable-cost counter: account, managed SKU, target, fresh observation, briefing, conversation, simulation, approval flow, execution attempt.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (cost_kind) (increase(analytics_cost_minor_units[1h]))",
          "legendFormat": "{{cost_kind}}",
          "refId": "V",
          "range": true
        }
      ]
    },
    {
      "id": 50,
      "type": "timeseries",
      "title": "Variable cost by source surface (24h)",
      "description": "Daily variable cost by source surface (bounded label). Per-ACCOUNT cost drill-down is intentionally NOT a Prometheus label (tenant UUID = unbounded/tenant-sensitive cardinality, issue #151); daily model-spend budget attribution per account lives in the authorized/persisted analytics query plane, not metrics.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (source_surface) (increase(analytics_cost_minor_units[24h]))",
          "legendFormat": "{{source_surface}}",
          "refId": "X",
          "range": true
        }
      ]
    }
  ]
}
