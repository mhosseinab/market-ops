{
  "uid": "dk-observation",
  "title": "DK · Observation quality, freshness & route cost",
  "description": "Observation capture quality, freshness tiers, and route budget cost.",
  "tags": [
    "dk-p0",
    "observation"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 19,
      "type": "timeseries",
      "title": "Observation events (capture/quality/freshness/drift)",
      "description": "§18 observation family: capture, quality, freshness, drift, route budget.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (name) (rate(analytics_events{family=\"observation\"}[15m]))",
          "legendFormat": "{{name}}",
          "refId": "S",
          "range": true
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Route/observation variable cost",
      "description": "§17.3 observation/route cost (minor units). Observation budgets reduce targets before widening freshness.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(analytics_cost_minor_units{cost_kind=\"successful_fresh_observation\"}[1h]))",
          "legendFormat": "fresh_observation",
          "refId": "U",
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(analytics_cost_minor_units{cost_kind=\"target\"}[1h]))",
          "legendFormat": "target",
          "refId": "V",
          "range": true
        }
      ]
    }
  ]
}
